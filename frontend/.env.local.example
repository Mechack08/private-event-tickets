# Backend API base URL (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Midnight ZK proof server URL (server-side only — never exposed to the browser).
# End users do NOT need Docker. You (the developer) must host this service.
#
# For local development:
#   docker run -d --rm -p 6300:6300 midnightntwrk/proof-server
#   PROOF_SERVER_URL=http://localhost:6300
#
# For production, deploy midnightntwrk/proof-server on a VPS/cloud and set:
#   PROOF_SERVER_URL=https://your-proof-server.example.com
#
# Note: Lace wallet does not support in-wallet proof generation (getProvingProvider),
# so it always routes through this server. 1AM wallet handles proofs internally.
PROOF_SERVER_URL=http://localhost:6300

# Google OAuth client ID — must match GOOGLE_CLIENT_ID in backend/.env
# Obtain from https://console.cloud.google.com/ → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_me_with_your_google_client_id.apps.googleusercontent.com
