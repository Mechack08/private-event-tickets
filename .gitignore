# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ────────────────────────────────────────────────────────────

# Contract: compiled artefacts (generated by `compact compile`)
generated/

# Contract: ZK proving keys are large binaries — regenerate with `pnpm contract:build`
# If you want to commit the WASM + JS module but not the keys:
# !generated/managed/event-tickets/contract/index.cjs
# !generated/managed/event-tickets/contract/index.d.ts
# !generated/managed/event-tickets/contract/contract.wasm

# SDK TypeScript output
sdk/dist/

# Frontend Next.js output
frontend/.next/
frontend/out/

# Frontend: compiled contract artefacts served from /public
# (copied from generated/ by `pnpm contract:copy`)
frontend/public/contracts/

# ── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test / coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Docker ───────────────────────────────────────────────────────────────────
# (nothing to ignore — proof server is pulled from Docker Hub at runtime)

# ── Backend build ─────────────────────────────────────────────────────────────
backend/dist/
