# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose defaults (matches docker-compose.yml)
DATABASE_URL="postgresql://pet_user:pet_pass@localhost:5433/pet_db?schema=public"

# Docker Compose settings (only needed if you change the defaults)
POSTGRES_USER=pet_user
POSTGRES_PASSWORD=pet_pass
POSTGRES_DB=pet_db
POSTGRES_PORT=5432

# pgAdmin (optional, launched with: pnpm db:ui)
PGADMIN_EMAIL=admin@localhost.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 random characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_a_random_64_char_hex_string_at_least_32_chars
SESSION_NAME=pet.sid
# Session TTL in seconds (default: 7 days)
SESSION_TTL_SECONDS=604800

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
