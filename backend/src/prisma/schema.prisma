// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ─────────────────────────────────────────────────────────────────────
// Identified by their Midnight shielded address (Bech32m, unique per wallet).
model User {
  id              String   @id @default(uuid()) @db.Uuid
  shieldedAddress String   @unique @db.VarChar(200)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hostedEvents    Event[]   @relation("HostedBy")
  tickets         Ticket[]

  @@index([shieldedAddress])
}

// ── Event ─────────────────────────────────────────────────────────────────────
// Off-chain metadata for an on-chain deployed event contract.
model Event {
  id              String      @id @default(uuid()) @db.Uuid
  // On-chain contract address (identifies the deployed Compact contract)
  contractAddress String      @unique @db.VarChar(200)
  name            String      @db.VarChar(200)
  description     String      @db.Text
  // Full formatted address (e.g. from Nominatim reverse geocoding)
  location        String      @db.Text
  // Structured location fields (extracted from map or entered manually)
  country         String?     @db.VarChar(100)
  city            String?     @db.VarChar(200)
  latitude        Float?
  longitude       Float?
  // Events have an explicit start and end — multi-day events are supported
  startDate       DateTime
  endDate         DateTime
  maxCapacity     Int
  ticketPrice     BigInt      @default(0)   // in tDUST (smallest unit)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  hostId          String      @db.Uuid
  host            User        @relation("HostedBy", fields: [hostId], references: [id], onDelete: Cascade)

  tickets         Ticket[]

  @@index([contractAddress])
  @@index([hostId])
  @@index([startDate])
}

// ── Ticket ────────────────────────────────────────────────────────────────────
// Off-chain record of a ticket issued on-chain.
// The cryptographic commitment is stored on-chain; we store the attendee
// binding and useful metadata here for fast lookups.
model Ticket {
  id              String        @id @default(uuid()) @db.Uuid
  // The ZK commitment hash that lives on-chain (hex string)
  commitment      String        @unique @db.VarChar(128)
  // Whether this ticket has been verified (spent) on-chain
  isVerified      Boolean       @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  eventId         String        @db.Uuid
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  attendeeId      String        @db.Uuid
  attendee        User          @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([attendeeId])
  @@index([commitment])
}
